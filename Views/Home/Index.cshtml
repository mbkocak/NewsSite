@model News_Site.Models.ViewModel.HomePageViewModel

@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}


<div class="row">
    
    <div class="col-md-8">
        <div id="carouselExampleCaptions" class="carousel slide mb-5" data-bs-ride="carousel">
            
            <div class="carousel-inner"  style="margin-top:15px;">
                @for (int i = 0; i < Model.SlideNews.Count; i++)
                {
                    var news = Model.SlideNews[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")" style="cursor:pointer;">
                        <a href="/News/Details/@news.Link" style="display:block; text-decoration:none; color:inherit;">
                            <img src="@news.Image" class="d-block w-100" alt="@news.NewsTitle" />
                            <div class="carousel-caption d-none d-md-block carousel-title-overlay">
                                <h5 class="display-6-fw-bold text-shadow">@news.NewsTitle</h5>
                            </div>
                        </a>
                    </div>
                }
            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Geri</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">İleri</span>
            </button>
        </div>
    </div>

   
    <div class="col-md-4">
        <hr />
        @foreach (var news in Model.SidebarNews)
        {
            <div class="card mb-3">
                <a href="/News/Details/@news.Link" style="text-decoration:none; color:inherit;">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <img src="@news.Image" class="img-fluid rounded-start" alt="@news.NewsTitle" style="height: 80px; object-fit: cover;" />
                        </div>
                        <div class="col-md-8">
                            <div class="card-body p-2">
                                <p class="card-text mb-0">@news.NewsTitle</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<hr class="w-100 mx-auto mb-4" />

<div class="row mt-4">
    @foreach (var news in Model.CardNews.Skip(3))
    {
        <div class="col-md-3 mb-4">
            <a href="/News/Details/@news.Link" style="text-decoration:none; color:inherit;">
                <div class="card h-100">
                    <img src="@news.Image" class="card-img-top" alt="@news.NewsTitle" style="height: 150px; object-fit: cover;" />
                    <div class="card-body">
                        <p class="card-text">@news.NewsTitle</p>
                    </div>
                </div>
            </a>
        </div>
    }
</div>


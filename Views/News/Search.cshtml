@model News_Site.Models.ViewModel.SearchViewModel

@{
    ViewData["Title"] = "Arama Sonuçları";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title">Arama Sonuçları</h2>
    <a href="/Home/Index" class="btn btn-outline-primary">
        <i class="bx bx-arrow-back me-2"></i>Geri Dön
    </a>
</div>

@if (!Model.NewsResults.Any())
{
    <div class="alert alert-warning" style="margin-bottom: 10rem;">
        @Model.NotFoundMessage
    </div>

    
    <div class="row mt-4">
        <h3 class="custom-section-title">İnceleyebileceğiniz diğer haberler</h3>

        <hr />

        
        @foreach (var news in Model.OtherNews.Take(12))
        {
            <div class="col-md-3 mb-4">
                <a href="/News/Details/@news.Link" style="text-decoration:none; color:inherit;">
                    <div class="card h-100">
                        <img src="@news.Image"
                             class="card-img-top"
                             alt="@news.NewsTitle"
                             style="height: 150px; object-fit: cover;" />
                        <div class="card-body">
                            <p class="card-text">@news.NewsTitle</p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

}



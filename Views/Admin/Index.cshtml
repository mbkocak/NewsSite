@using System.Text.Json
@model News_Site.Models.ViewModel.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Paneli Genel Bakış";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@using (Html.BeginForm("Index", "Admin", FormMethod.Post, new { @class = "card p-4" /* mb-4 kaldırıldı */ }))
{
    <div class="container-fluid mt-3 ">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="page-title fw-bold text-dark">Admin Panel</h5>
            <a href="/News/AddNews" class="btn btn-primary btn-sm me-3 d-flex align-items-center newBtn2">
                <i class="fas fa-plus-circle me-1"></i> Add News
            </a>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-xl-4 col-lg-6 col-md-6 col-sm-12">
                <a href="/Members/Index" class="text-decoration-none">
                    <div class="card bg-dark text-white shadow-lg border-0 rounded-4 h-100 transform-on-hover">
                        <div class="card-body p-4 d-flex flex-column justify-content-between align-items-center">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-users fa-lg me-2 text-info"></i>
                                <h6 class="card-title mb-0 fw-bold fs-5">Total Users</h6>
                            </div>
                            <p class="h2 fw-bolder mb-0 text-info">@Model.TotalUsers</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-xl-4 col-lg-6 col-md-6 col-sm-12">
                <a href="/News/Index" class="text-decoration-none">
                    <div class="card bg-dark text-white shadow-lg border-0 rounded-4 h-100 transform-on-hover">
                        <div class="card-body p-4 d-flex flex-column justify-content-between align-items-center">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-newspaper fa-lg me-2 text-info"></i>
                                <h6 class="card-title mb-0 fw-bold fs-5">Total News</h6>
                            </div>
                            <p class="h2 fw-bolder mb-0 text-info">@Model.TotalNews</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-xl-4 col-lg-6 col-md-6 col-sm-12">
                <a href="/Categories/Index" class="text-decoration-none">
                    <div class="card bg-dark text-white shadow-lg border-0 rounded-4 h-100 transform-on-hover">
                        <div class="card-body p-4 d-flex flex-column justify-content-between align-items-center">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-th-list fa-lg me-2 text-info"></i>
                                <h6 class="card-title mb-0 fw-bold fs-5">Categories</h6>
                            </div>
                            <p class="h2 fw-bolder mb-0 text-info">@Model.TotalCategories</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
}

<div class="row justify-content-center g-4 mt-0">
    <div class="col-xl-4 col-lg-6 col-md-8 col-sm-12">
        <div class="card shadow-lg border rounded-4 h-100" style="background-color: #212529; border-color: #495057 !important;">
            <div class="card-header text-white bg-dark border-bottom-0 rounded-top-4 py-3">
                <h5 class="mb-0 text-info text-center fw-bold">Percentages of User Roles</h5>
            </div>
            <div class="card-body p-4">
                <canvas id="roleDoughnutChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-lg-6 col-md-8 col-sm-12">
        <div class="card shadow-lg border rounded-4 h-100" style="background-color: #212529; border-color: #495057 !important;">
            <div class="card-header text-white bg-dark border-bottom-0 rounded-top-4 py-3">
                <h5 class="mb-0 text-info text-center fw-bold">News Distribution by Category</h5>
            </div>
            <div class="card-body p-4">
                <canvas id="categoryChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-lg-6 col-md-8 col-sm-12">
        <div class="card shadow-lg border rounded-4 h-100" style="background-color: #212529; border-color: #495057 !important;">
            <div class="card-header text-white bg-dark border-bottom-0 rounded-top-4 py-3">
                <h5 class="mb-0 text-info text-center fw-bold">Annual User Registration Trend</h5>
            </div>
            <div class="card-body p-4">
                <canvas id="userTrendChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-lg-6 col-md-8 col-sm-12">
        <div class="card shadow-lg border rounded-4 h-100" style="background-color: #212529; border-color: #495057 !important;">
            <div class="card-header text-white bg-dark border-bottom-0 rounded-top-4 py-3">
                <h5 class="mb-0 text-info text-center fw-bold">Daily News Added Count</h5>
            </div>
            <div class="card-body p-4">
                <canvas id="dailyNewsChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const categoryLabels = @Html.Raw(JsonSerializer.Serialize(Model.CategoryCounts.Select(c => c.CategoryName)));
    const categoryData = @Html.Raw(JsonSerializer.Serialize(Model.CategoryCounts.Select(c => c.NewsCount)));

    const ctxCategory = document.getElementById('categoryChart').getContext('2d');

    new Chart(ctxCategory, {
        type: 'bar',
        data: {
            labels: categoryLabels,
            datasets: [{
                label: 'News Number',
                backgroundColor: '#17a2b8',
                borderColor: '#17a2b8',
                borderWidth: 1,
                data: categoryData
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                },
                title: {
                    display: true,
                    text: 'Total Number of News by Category',
                    color: '#f8f9fa',
                    font: {
                        size: 16,
                        weight: 'bold'
                    }
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            let label = context.dataset.label || '';
                            if (label) {
                                label += ': ';
                            }
                            if (context.parsed.y !== null) {
                                label += context.parsed.y + ' haber';
                            }
                            return label;
                        }
                    }
                }
            },
            scales: {
                x: {
                    grid: {
                        color: 'rgba(255, 255, 255, 0.1)'
                    },
                    ticks: {
                        color: '#f8f9fa'
                        
                    }
                },
                y: {
                    beginAtZero: true,
                    grid: {
                        color: 'rgba(255, 255, 255, 0.1)'
                    },
                    ticks: {
                        color: '#f8f9fa'
                    }
                }
            }
        }
    });

    const userTrendLabels = ['2020', '2021', '2022', '2023', '2024', '2025'];
    const userTrendData = [150, 220, 300, 450, 580, 650];

    const ctxUserTrend = document.getElementById('userTrendChart').getContext('2d');

    new Chart(ctxUserTrend, {
        type: 'line',
        data: {
            labels: userTrendLabels,
            datasets: [{
                label: 'Number of Registered Users',
                data: userTrendData,
                borderColor: '#28a745',
                backgroundColor: 'rgba(40, 167, 69, 0.2)',
                tension: 0.4,
                fill: true,
                pointBackgroundColor: '#28a745',
                pointBorderColor: '#fff',
                pointHoverBackgroundColor: '#fff',
                pointHoverBorderColor: '#28a745',
                pointRadius: 5,
                pointHoverRadius: 7
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                },
                title: {
                    display: true,
                    text: 'Annual User Registration Trend',
                    color: '#f8f9fa',
                    font: {
                        size: 16,
                        weight: 'bold'
                    }
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            let label = context.dataset.label || '';
                            if (label) {
                                label += ': ';
                            }
                            if (context.parsed.y !== null) {
                                label += context.parsed.y + ' kullanıcı';
                            }
                            return label;
                        }
                    }
                }
            },
            scales: {
                x: {
                    grid: {
                        color: 'rgba(255, 255, 255, 0.1)'
                    },
                    ticks: {
                        color: '#f8f9fa'
                    }
                },
                y: {
                    beginAtZero: true,
                    grid: {
                        color: 'rgba(255, 255, 255, 0.1)'
                    },
                    ticks: {
                        color: '#f8f9fa'
                    }
                }
            }
        }
    });

    const roleLabels = @Html.Raw(JsonSerializer.Serialize(Model.RoleDistributions.Select(r => r.RoleName)));
    const roleData = @Html.Raw(JsonSerializer.Serialize(Model.RoleDistributions.Select(r => r.Count)));

    const ctxRole = document.getElementById('roleDoughnutChart').getContext('2d');

    new Chart(ctxRole, {
        type: 'doughnut',
        data: {
            labels: roleLabels,
            datasets: [{
                data: roleData,
                backgroundColor: ['#17a2b8', '#9370DB'],
                hoverBackgroundColor: ['#17a2b8', '#663399'],
                hoverOffset: 10
            }]
        },
        options: {
            responsive: true,
            cutout: '70%',
            plugins: {
                legend: {
                    display: true,
                    labels: {
                        color: '#f8f9fa'
                    }
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            let total = context.chart.data.datasets[0].data.reduce((a, b) => a + b, 0);
                            let value = context.parsed;
                            let percentage = ((value / total) * 100).toFixed(1);
                            return `${context.label}: ${value} kişi (%${percentage})`;
                        }
                    }
                },
                title: {
                    display: true,
                    text: 'User Role Distribution',
                    color: '#f8f9fa',
                    font: {
                        size: 16,
                        weight: 'bold'
                    }
                }
            }
        }
    });

    const dailyNewsCtx = document.getElementById('dailyNewsChart').getContext('2d');

        const dailyNewsChart = new Chart(dailyNewsCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.DailyNewsCounts.Select(x => x.Date))),
                datasets: [{
                    label: 'News Count',
                    data: @Html.Raw(Json.Serialize(Model.DailyNewsCounts.Select(x => x.Count))),
                    fill: false,
                    borderColor: 'rgba(75, 192, 192, 1)',
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'top'
                    },
                    title: {
                        display: true,
                        text: 'Last 7 days'
                    }
                }
            }
        });
</script>
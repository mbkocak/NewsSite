@inject News_Site.Models.Entity.NewsSiteContext db

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-..." crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-..." crossorigin="anonymous"></script>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <div class="sticky-top-navbar">
        <header class="bg-dark text-white py-2">
            <div class="container d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <a class="navbar-brand me-2" href="/Home/Index">
                        <img src="/images/doruk2.png" alt="Haber Sitesi" width="34" height="30" />
                    </a>
                    <a class="navbar-brand me-2" href="/Home/Index">
                        <h1 class="h4 mb-0">Doruk Haber</h1>
                    </a>

                </div>

                <div class="social-media">
                    <a href="#">
                        <i class='bx bxl-instagram'></i>
                    </a>
                    <a href="#">
                        <i class='bx bxl-twitter'></i>
                    </a>
                    <a href="#">
                        <i class='bx bxl-facebook-circle'></i>
                    </a>

                </div>

            </div>
        </header> 
        <nav class="navbar navbar-expand-lg bg-body-tertiary">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        @foreach (var category in db.Categories.ToList())
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("CategoryDetails", "News", new { categoryName = category.CategoryName })">@category.CategoryName</a>
                            </li>
                        }
                    </ul>

                </div>

                <form class="d-flex" role="search" method="get" asp-controller="News" asp-action="Search">
                    <input class="form-control me-2" type="search" name="query" placeholder="Haber ara..." aria-label="Search" required />
                    <button class="btn btn-outline-primary" type="submit">Search</button>
                </form>
            </div>
        </nav>
    </div>

    <div class="alert alert-info d-flex justify-content-around newAlert">
        <span><strong>USD:</strong> @Model.Currencies["USD"] ₺</span>
        <span><strong>EUR:</strong> @Model.Currencies["EUR"] ₺</span>
        <span><strong>GBP:</strong> @Model.Currencies["GBP"] ₺</span>
        <span><strong>Bitcoin (BTC):</strong> @Model.Currencies["BTC"] ₺</span>
        <span><strong>BIST100:</strong> @Model.Currencies["BIST100"]</span>
        <span><strong>Faiz:</strong> @Model.Currencies["Faiz"] %</span>
    </div>  

    

    <div>
        @RenderBody()
    </div>

    <footer class="bg-dark text-white mt-5 py-4">
        <div class="container">
            <div class="row">
               
                <div class="col-md-4 mb-3">
                    <h5>Hakkımızda</h5>
                    <p>Bu haber sitesi güncel ve güvenilir haberleri sizlere sunar. Bizi takipte kalın!</p>
                </div>


                <div class="col-md-4 mb-3">
                    <h5>İletişim</h5>
                    <p>Email: info@habersitesi.com</p>
                    <p>Telefon: +90 555 123 4567</p>
                    <p>Adres: İstanbul, Türkiye</p>
                </div>
            </div>
            <div class="text-center mt-3 small">
                &copy; 2025 Doruk Haber. Tüm hakları saklıdır.
            </div>
        </div>
    </footer>

</body>
</html>


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-..." crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/admin.css" />
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <div class="sidebar" id="sidebar">
        <div class="logo-content">
            <div class="logo">
                <i class='bx  bx-user'></i>
                <h3 class="links-name">Admin</h3>
            </div>
            <i class='bx bx-menu' id="btn"></i>
        </div>
        <ul class="nav-list">
            <li>
                <i class='bx  bx-search'></i>
                <input type="text" placeholder="Search...">
                <span class="tooltip">Search</span>
            </li>

            <li>
                <a href="/Admin/Index">
                    <i class='bx bx-category'></i>
                    <span class="links-name">Dashboard</span>
                </a>
                <span class="tooltip">Home</span>
            </li>

            <li>
                <a href="/Home/Index">
                    <i class='bx  bx-home-alt'></i>
                    <span class="links-name">Home</span>
                </a>
                <span class="tooltip">Home</span>
            </li>

            <li>
                <a href="/Members/Index">
                    <i class='bx bx-user'></i>
                    <span class="links-name">Members</span>
                </a>
                <span class="tooltip">Members</span>
            </li>
            <li>
                <a href="/Categories/Index">
                    <i class='bx bx-folder'></i>
                    <span class="links-name">Categories</span>
                </a>
                <span class="tooltip">Category</span>
            </li>

            <li>
                <a href="/News/Index">
                    <i class='bx  bx-news'></i>
                    <span class="links-name">News</span>
                </a>
                <span class="tooltip">News</span>
            </li>

            <li>
                <a href="/Comments/Index">
                    <i class='bx bx-message-dots'></i>
                    <span class="links-name">Comments</span>
                </a>
                <span class="tooltip">Comments</span>
            </li>

            <li>
                <a href="/Emote/Index">
                    <i class='bx  bx-laugh'></i>
                    <span class="links-name">Emotes</span>
                </a>
                <span class="tooltip">Emotes</span>
            </li>


        </ul>

        <ul class="list-logout">
            <li>
                <a href="/User/Login/Index">
                    <i class='bx  bx-door-open'></i>
                    <span class="links-name">Logout</span>
                </a>
                <span class="tooltip">Logouts</span>
            </li>

        </ul>
        
        <div class="profile-content">
        </div>
    </div>

    <div class="main-content">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </div>

    

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-..." crossorigin="anonymous"></script>
    <script src="/js/admin2.js" defer></script>
    <script>
        let sidebar = document.querySelector(".sidebar");
        let menuBtn = document.querySelector("#btn");

        menuBtn.onclick = function() {
            sidebar.classList.toggle("active");
        }
    </script>
</body>
</html>
  @using News_Site.Controllers
@model IEnumerable<News_Site.Models.Entity.User>
@{
    ViewData["Title"] = "Members";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-wrapper p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="page-title">Members</h2>
    </div>

    

    @using (Html.BeginForm("Index", "Members", FormMethod.Post, new { @class = "card p-4 mb-4" }))
    {
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-4">
                <label for="UserName" class="form-label">User Name:</label>
                @Html.TextBox("UserName", null, new { @class = "form-control newInput", id = "UserName", placeholder = "User Name" })
            </div>
            <div class="col-md-4">
                <label for="UserSurname" class="form-label">User Surname:</label>
                @Html.TextBox("UserSurname", null, new { @class = "form-control newInput", id = "UserSurname", placeholder = "User Surname" })
            </div>
            <div class="col-md-4">
                <label for="UserEmail" class="form-label">E-mail:</label>
                @Html.TextBox("UserEmail", null, new { @class = "form-control newInput", id = "UserEmail", placeholder = "E-mail" })
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-12 text-end">
                <button type="submit" class="btn btn-dark newBtn">
                    <i class="bx bx-search-alt-2 me-2"></i>Search
                </button>
                <button type="button" class="btn btn-dark newBtn" id="clearFiltersBtn">
                    <i class="bx bx-x me-2"></i>Clear Filters
                </button>
            </div>
        </div>
    }

    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        @if (TempData["DeleteMessage"] != null)
        {
            <div class="toast show text-bg-danger" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <strong>Success!</strong> @TempData["DeleteMessage"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }

    </div>
        
    <div class="card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle newTbl">
                <thead class="table-dark">
                    <tr>
                        <th>User Name</th>
                        <th>User Surname</th>
                        <th>E-posta</th>
                        <th>Is Admin</th>
                        <th class="text-center">Buttons</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.UserName</td>
                                <td>@user.UserSurname</td>
                                <td>@user.UserEmail</td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-inline-block">
                                        <input class="form-check-input admin-toggle"
                                               type="checkbox"
                                               role="switch"
                                               id="switch-@user.UserId"
                                               data-user-id="@user.UserId"
                                        @(user.IsAdmin ? "checked" : "")>
                                        <label class="form-check-label" for="switch-@user.UserId">
                                            @(user.IsAdmin ? "Admin" : "Üye")
                                        </label>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <a href="javascript:void(0);" onclick="confirmDelete('@Url.Action("Delete", new { id = user.UserId })')" class="btn btn-sm btn-outline-danger">
                                        <i class="bx bx-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted p-4">
                                This user not found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>

        document.getElementById('clearFiltersBtn').addEventListener('click', function () {
        document.getElementById('UserName').value = '';
        document.getElementById('UserSurname').value = '';
        document.getElementById('UserEmail').value = '';

        this.closest('form').submit();
    });

    function confirmDelete(url) {
        if (confirm('Are you sure?')) {
            window.location.href = url;
        }
    }

    document.querySelectorAll(".admin-toggle").forEach(function (checkbox) {
        checkbox.addEventListener("change", function () {
            var userId = this.getAttribute("data-user-id");
            var isAdmin = this.checked;
            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            fetch('/Members/ToggleAdmin', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ userId: userId, isAdmin: isAdmin })
            })
            .then(response => {
                if (!response.ok) {
                    alert("Yönetici yetkisi güncellenirken bir hata oluştu.");
                }
            })
            .catch(error => {
                console.error('Fetch hatası:', error);
                alert("Yönetici yetkisi güncellenirken bir hata oluştu.");
            });

            let label = this.nextElementSibling;
            if (label) {
                label.textContent = isAdmin ? "Admin" : "Üye";
            }
        });
    });
</script>